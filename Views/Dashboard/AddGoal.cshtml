@{
    ViewData["Title"] = "Add Goals";

}

<div class="text-center">
    <h1 class="display-4">Add Your New Product</h1>

</div>

<form asp-controller="Dashboard" asp-action="AddGoalItem" method="post">
    <div class="mb-3">
        <label for="name" class="form-label">Goal Name</label>
        <input type="text" class="form-control" id="GoalName" name="GoalName" placeholder="Enter goal name: " />
    </div>
    <div class="mb-3">
        <label for="GoalAmount" class="form-label">Number of hours dedicated to this goal per week</label>
        <input type="text" class="form-control" id="GoalHoursAmount" name="GoalHoursAmount" placeholder="Enter a number of hours " />
    </div>
    <button type="submit" class="btn btn-success">Add Product</button>"
</form>
